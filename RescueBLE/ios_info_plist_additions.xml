<?xml version="1.0" encoding="UTF-8"?>
<!--
  Agregar estas keys al Info.plist de iOS (ios/RescueBLE/Info.plist)
  dentro del <dict> principal.
-->
<dict>

  <!-- Descripción de por qué usamos Bluetooth (requerido por App Store) -->
  <key>NSBluetoothAlwaysUsageDescription</key>
  <string>Rescue BLE usa Bluetooth para detectar dispositivos de víctimas cercanas o para emitir una señal de socorro que los rescatistas puedan localizar.</string>

  <key>NSBluetoothPeripheralUsageDescription</key>
  <string>Rescue BLE necesita Bluetooth para emitir una señal de localización en modo víctima.</string>

  <!-- Background modes para BLE activo con pantalla bloqueada -->
  <key>UIBackgroundModes</key>
  <array>
    <!-- Permite scan BLE en background -->
    <string>bluetooth-central</string>
    <!-- Permite advertising BLE en background (modo víctima) -->
    <string>bluetooth-peripheral</string>
  </array>

  <!--
    NOTA SOBRE ADVERTISING EN iOS:
    iOS no permite advertising BLE genérico en background con react-native-ble-advertiser.
    Sin embargo, SÍ permite iBeacon advertising via CoreLocation en background con
    el entitlement com.apple.developer.location.always y CLLocationManager.
    
    Alternativa más robusta en iOS: usar CoreBluetooth CBPeripheralManager 
    via un módulo nativo Swift puente.
    
    Para un MVP rápido en iOS, el modo víctima puede:
    1. Mantener pantalla activa (KeepAwake) + advertise en foreground
    2. Emitir audio de alta frecuencia para detectores físicos
    3. Usar audio tone + máximo volumen como señal secundaria
  -->

</dict>
